"""
# import collections => 자료구조를 더 편하게 쓰도록 도와주는 표준 라이브러리
1. Counter : 개수 세는 전용 도구
words = ["a","b","a","c","b","a"]
print(Counter(words)) / {'a':3,'b':2,'c':1}
counts.most_common(1) : 가장 많이 사용
2. deque(큐/스택 최강자) : 앞뒤에서 빠르게 넣고 빼기
d = deque([1,2,3])  / d.append(4)/d.appendleft(0)/d.pop() / d.popleft()
3. defaultdict : 키 없을 때 자동 생성
d = defaultdict(int)
d["a"]+=1 / print(d) / {'a':1}
"""

import re
import collections
from typing import List

def mostCommonWord(paragraph: str, banned: List[str]) -> str:
    words = [word for word in re.sub(r'[^\w]', ' ', paragraph)
             .lower().split()
             if word not in banned]

    counts = collections.Counter(words)
    return counts.most_common(1)[0][0]

paragraph = "Bob hit a ball, the hit BALL flew far after it was hit."
banned =["hit"]
a = mostCommonWord(paragraph, banned)
print(a)


