"""
투포인트방식
1. return 없음 : 결과 반환x/ 결과 반환 return s 선언문 none 지움
2. 리스트를 직접 바꿈 (in-place) 
""" 

def reverseString(s:list[str] )-> None:
    left, right = 0, len(s)-1                    #  left(맨앞)/right(맨뒤)
    while left<right:                            # 서로 만나기 전까지 반복
        s[left], s[right] = s[right], s[left]    # 동시교환(swap)
        left+=1
        right-=1                                 # 결과 : None 리스트를 자체 변경

#파이썬 방식
def reverseString(s:list[str]) -> None:
    s.reverse()
